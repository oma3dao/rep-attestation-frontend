# Web3Auth Client ID (public, get from https://dashboard.web3auth.io)
NEXT_PUBLIC_WEB3AUTH_CLIENT_ID=your_client_id_here

# WalletConnect Project ID for Web3Auth adapter (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_wc_project_id_here

# Web3Auth Client Secret (server-side only, keep secure)
WEB3AUTH_CLIENT_SECRET=your_secret_here
