# OMATrust Reputation Frontend — Environment Variables
#
# The active chain determines the environment prefix for all service URLs:
#   omachain-mainnet  → no prefix  (e.g., backend.omatrust.org)
#   omachain-testnet  → preview.   (e.g., preview.backend.omatrust.org)
#   omachain-devnet   → dev.       (e.g., dev.backend.omatrust.org)

# Thirdweb Client ID
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_client_id_here

# Active Chain — determines chain config, contract addresses, and environment prefix
NEXT_PUBLIC_ACTIVE_CHAIN=omachain-testnet

# Optional: Enable debug logging
NEXT_PUBLIC_DEBUG_ADAPTER=true

# ============================================
# Service Domains
# ============================================
# Base domains for OMATrust services. The active chain determines the
# environment prefix (preview., dev., or none for production).
# Override with localhost:PORT for local development.

# OMATrust backend (account, session, relay flows)
# NEXT_PUBLIC_OMATRUST_BACKEND_DOMAIN=backend.omatrust.org
# Local dev: NEXT_PUBLIC_OMATRUST_BACKEND_DOMAIN=localhost:3001

# OMATrust API gateway (controller witness, trust anchors)
# NEXT_PUBLIC_OMATRUST_API_DOMAIN=api.omatrust.org
# Local dev: NEXT_PUBLIC_OMATRUST_API_DOMAIN=localhost:3002

# ============================================
# Delegated Attestation (Server-side)
# ============================================

# EAS Delegate private key for testnet delegated attestations
# For local dev, you can also use ~/.ssh/local-attestation-key file (shared with app-registry-frontend)
# Generate: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))" > ~/.ssh/local-attestation-key && chmod 600 ~/.ssh/local-attestation-key
# EAS_DELEGATE_PRIVATE_KEY=0x...

# Maximum gas per delegated attestation transaction (default: 800000)
# MAX_GAS_PER_TX=800000

# ============================================
# Review Widget
# ============================================

# Widget base URL — determines where the review widget iframe loads from.
# Must match the environment:
#   Local dev:  http://localhost:3000
#   Preview:    https://preview.widgets.omatrust.org
#   Production: https://widgets.omatrust.org (or omit to use default)
# Also used as the devOriginOverride for the SDK signing bridge.
# NEXT_PUBLIC_WIDGET_BASE_URL=http://localhost:3000
