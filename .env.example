# Thirdweb Client ID
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your_client_id_here

# Active Chain (omachain-testnet or omachain-mainnet)
# This determines which chain the frontend targets - NOT the user's wallet
NEXT_PUBLIC_ACTIVE_CHAIN=omachain-testnet

# Optional: Enable debug logging
NEXT_PUBLIC_DEBUG_ADAPTER=true

# ============================================
# Delegated Attestation (Server-side)
# ============================================

# EAS Delegate private key for testnet delegated attestations
# For local dev, you can also use ~/.ssh/eas-delegate-key file
# Generate: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
# EAS_DELEGATE_PRIVATE_KEY=0x...

# Maximum gas per delegated attestation transaction (default: 300000)
# MAX_GAS_PER_TX=300000
